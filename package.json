{
  "name": "creatordash",
  "version": "1.0.0",
  "description": "Creator analytics dashboard with historical tracking and posting capabilities",
  "type": "module",
  "scripts": {
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next build && next export",
    "server": "node server.mjs",
    "db:init": "node scripts/db-init.mjs",
    "db:migrate:instagram": "node scripts/db-migrate-instagram.mjs",
    "db:migrate:posting": "node scripts/db-migrate-posting.mjs",
    "fetch": "node scripts/fetch-and-save.mjs",
    "fetch:dry": "node scripts/fetch-and-save.mjs --dry-run",
    "fetch:instagram": "node scripts/fetch-instagram.mjs",
    "fetch:instagram:dry": "node scripts/fetch-instagram.mjs --dry-run",
    "fetch:all": "npm run fetch && npm run fetch:instagram",
    "report": "node scripts/generate-full-report.mjs",
    "report:legacy": "node scripts/generate-report.mjs",
    "report:weekly": "node scripts/generate-full-report.mjs --weekly",
    "report:monthly": "node scripts/generate-full-report.mjs --monthly",
    "post": "node scripts/post.mjs",
    "post:youtube": "node scripts/post-to-youtube.mjs",
    "post:instagram": "node scripts/post-to-instagram.mjs",
    "post:scheduled": "node scripts/post.mjs --process-scheduled",
    "post:list": "node scripts/post.mjs --list-scheduled"
  },
  "dependencies": {
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  }
}
